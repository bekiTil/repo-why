{
  "name": "repo-why",
  "displayName": "Repo Why",
  "description": "Understand any codebase with an AI assistant. Visualize dependencies, ask questions, get answers grounded in your code.",
  "version": "0.2.0",
  "publisher": "bekiTil",
  "author": {
    "name": "Beki",
    "email": "btilahun287@gmail.com"
  },
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/bekiTil/repo-why"
  },
  "bugs": {
    "url": "https://github.com/bekiTil/repo-why/issues"
  },
  "homepage": "https://github.com/bekiTil/repo-why#readme",
  "engines": {
    "vscode": "^1.103.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "ai",
    "codebase",
    "graph",
    "dependency",
    "chat",
    "groq",
    "code understanding"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "repoWhy",
          "title": "Repo Why",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "repoWhy": [
        {
          "id": "repoWhy.sidebar",
          "name": "Repo Why",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "repo-why.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "repoWhy.askWhy",
        "title": "Repo Why: Why does this exist?",
        "category": "Repo Why"
      },
      {
        "command": "repoWhy.openInEditor",
        "title": "Repo Why: Open in Editor Tab",
        "category": "Repo Why",
        "icon": "$(link-external)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "repoWhy.askWhy",
          "when": "editorHasSelection",
          "group": "navigation@99"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.103.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "simple-git": "^3.36.0"
  }
}
